<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>EduLearn - Complete Website</title>

<style>
*{
  margin:0;
  padding:0;
  box-sizing:border-box;
  font-family: Arial, sans-serif;
  scroll-behavior:smooth;
}

body{
  background:#f5f7fb;
  color:#333;
}

/* NAVBAR */
.navbar{
  background:#4F46E5;
  padding:15px;
  position:sticky;
  top:0;
  z-index:1000;
  text-align:center;
}

.navbar a{
  color:white;
  text-decoration:none;
  margin:0 10px;
  font-weight:500;
}

/* SECTIONS */
.section{
  padding:80px 10%;
  min-height:100vh;
}

.hero{
  background:#e0e7ff;
  text-align:center;
}

.hero h1{
  font-size:40px;
  margin-bottom:20px;
}

/* BUTTON */
.btn{
  display:inline-block;
  padding:10px 20px;
  background:#4F46E5;
  color:white;
  text-decoration:none;
  border-radius:5px;
  margin-top:15px;
  border:none;
  cursor:pointer;
}

.btn:hover{
  background:#3730a3;
}

/* CARDS */
.cards{
  display:flex;
  gap:20px;
  margin-top:30px;
  flex-wrap:wrap;
}

.card{
  background:white;
  padding:20px;
  border-radius:8px;
  flex:1;
  min-width:250px;
  box-shadow:0 2px 8px rgba(0,0,0,0.1);
}

/* FORMS */
form{
  background:white;
  width:400px;
  max-width:100%;
  padding:30px;
  border-radius:8px;
  box-shadow:0 2px 8px rgba(0,0,0,0.1);
}

form input, form textarea{
  width:100%;
  padding:10px;
  margin:10px 0;
  border:1px solid #ccc;
  border-radius:5px;
}

/* DASHBOARD */
.dashboard{
  display:flex;
  flex-wrap:wrap;
}

.sidebar{
  width:220px;
  background:#4F46E5;
  color:white;
  min-height:100vh;
  padding:20px;
}

.sidebar a{
  display:block;
  color:white;
  text-decoration:none;
  margin:15px 0;
}

.dashboard-content{
  flex:1;
  padding:40px;
}

/* FOOTER */
.footer{
  background:#111827;
  color:white;
  text-align:center;
  padding:20px;
}

/* RESPONSIVE */
@media(max-width:768px){
  .cards{
    flex-direction:column;
  }
  .dashboard{
    flex-direction:column;
  }
  .sidebar{
    width:100%;
    min-height:auto;
  }
}
</style>
</head>

<body>

<!-- NAVIGATION -->
<div class="navbar">
  <a href="#home">Home</a>
  <a href="#courses">Courses</a>
  <a href="#details">Details</a>
  <a href="#about">About</a>
  <a href="#pricing">Pricing</a>
  <a href="#contact">Contact</a>
  <a href="#login">Login</a>
  <a href="#signup">Sign Up</a>
  <a href="#dashboard">Dashboard</a>
  <a href="#mycourses">My Courses</a>
</div>

<!-- 1 HOME -->
<section id="home" class="section hero">
  <h1>Upgrade Your Skills Online</h1>
  <p>Learn from industry experts worldwide</p>
  <a href="#courses" class="btn">Explore Courses</a>

  <div class="cards">
    <div class="card">
      <h3>Web Development</h3>
      <p>HTML, CSS, JavaScript</p>
    </div>
    <div class="card">
      <h3>UI/UX Design</h3>
      <p>Figma & Prototyping</p>
    </div>
    <div class="card">
      <h3>Data Science</h3>
      <p>Python & Machine Learning</p>
    </div>
  </div>
</section>

<!-- 2 COURSES -->
<section id="courses" class="section">
  <h1>All Courses</h1>
  <div class="cards">
    <div class="card">
      <h3>Web Development</h3>
      <p>Beginner to Advanced</p>
    </div>
    <div class="card">
      <h3>UI/UX Design</h3>
      <p>Complete Design System</p>
    </div>
  </div>
</section>

<!-- 3 COURSE DETAILS -->
<section id="details" class="section">
  <h1>Web Development Course</h1>
  <p><strong>Instructor:</strong> John Doe</p>
  <p>This course covers HTML, CSS, and JavaScript from scratch to advanced level.</p>
  <button class="btn">Enroll Now</button>
</section>

<!-- 4 ABOUT -->
<section id="about" class="section">
  <h1>About Us</h1>
  <p>EduLearn provides high-quality online education to students around the world.</p>
</section>

<!-- 5 PRICING -->
<section id="pricing" class="section">
  <h1>Pricing Plans</h1>
  <div class="cards">
    <div class="card">
      <h3>Basic</h3>
      <p>$10 / month</p>
    </div>
    <div class="card">
      <h3>Pro</h3>
      <p>$20 / month</p>
    </div>
  </div>
</section>

<!-- 6 CONTACT -->
<section id="contact" class="section">
  <h1>Contact Us</h1>
  <form>
    <input type="text" placeholder="Your Name">
    <input type="email" placeholder="Your Email">
    <textarea placeholder="Your Message"></textarea>
    <button class="btn">Send</button>
  </form>
</section>

<!-- 7 LOGIN -->
<section id="login" class="section">
  <h1>Login</h1>
  <form>
    <input type="email" placeholder="Email">
    <input type="password" placeholder="Password">
    <button class="btn">Login</button>
  </form>
</section>

<!-- 8 SIGN UP -->
<section id="signup" class="section">
  <h1>Sign Up</h1>
  <form>
    <input type="text" placeholder="Full Name">
    <input type="email" placeholder="Email">
    <input type="password" placeholder="Password">
    <button class="btn">Register</button>
  </form>
</section>

<!-- 9 DASHBOARD -->
<section id="dashboard" class="section">
  <div class="dashboard">
    <div class="sidebar">
      <h3>Student Panel</h3>
      <a href="#dashboard">Dashboard</a>
      <a href="#mycourses">My Courses</a>
    </div>

    <div class="dashboard-content">
      <h1>Welcome Back!</h1>
      <div class="cards">
        <div class="card">Enrolled Courses: 3</div>
        <div class="card">Completed Courses: 1</div>
      </div>
    </div>
  </div>
</section>

<!-- 10 MY COURSES -->
<section id="mycourses" class="section">
  <h1>My Courses</h1>
  <div class="card">
    <h3>Web Development</h3>
    <p>Progress: 60%</p>
  </div>
</section>

<div class="footer">
  © 2026 EduLearn | All Rights Reserved
</div>

</body>
</html>
